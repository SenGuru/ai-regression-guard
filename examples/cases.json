{
  "run_id": "support_ticket_classifier",
  "schema": {
    "category": {
      "type": "string",
      "enum": ["billing", "technical", "account", "other"]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "summary": {
      "type": "string"
    }
  },
  "scorer_weights": {
    "refusal": 0.3,
    "schema": 0.7
  },
  "outputs": [
    {
      "category": "billing",
      "priority": "high",
      "summary": "Customer unable to process payment"
    },
    {
      "category": "technical",
      "priority": "medium",
      "summary": "API timeout on checkout"
    },
    {
      "category": "account",
      "priority": "low",
      "summary": "User wants to update email"
    }
  ]
}
